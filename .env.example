# ============================================================
# StockSage Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Flask secret key - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///stocksage.db
# PostgreSQL example: DATABASE_URL=postgresql://user:pass@host/dbname

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True

# ── FREE APIs ──────────────────────────────────────────────

# Anthropic Claude AI (free tier at console.anthropic.com)
# Used for: AI stock insights. Falls back to rule-based if not set.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# NewsAPI (free at newsapi.org — 100 req/day)
# Used for: fallback news. App works without it via RSS feeds.
NEWS_API_KEY=your-newsapi-key-here

# ── EMAIL ALERTS (optional) ────────────────────────────────
# Gmail SMTP — use an App Password (not your real password)
# Guide: myaccount.google.com/apppasswords
# Leave blank to disable email; alerts still show in the UI.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=your-gmail@gmail.com
